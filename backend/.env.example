# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/drfoods?schema=public"

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# AI
ANTHROPIC_API_KEY=

# Payments (Paystack) - sandbox keys, not required for the mock checkout path
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# SMS (Termii) - not yet integrated, reserved for phone OTP
TERMII_API_KEY=
